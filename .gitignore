# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt
npm-debug.log*

/.idea
/.ionic
/.sass-cache
/.sourcemaps
/.versions
/.vscode
/coverage
/dist
/node_modules
/platforms
/plugins
/www
*.cache

# Angular build cache
/.angular

# Firestore emulator local state (when emulators are used)
/data
/firebase-debug.log
/firestore-debug.log
/ui-debug.log

# Local scratchpads (not part of project source)
/404s.txt
/greenflagged-*.md
/greenflagged-*.txt

# Empty project-local MCP config — don't commit
/.mcp.json
