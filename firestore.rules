rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Default deny — overridden by more specific matches below.
    match /{document=**} {
      allow read, write: if false;
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // Writes only happen server-side via the admin SDK (onDeleteGame).
    // Reads stay open to support the deleted-games recovery UI in
    // game-detail / game-history.
    match /deletedGames/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /eloHistory/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /userToUserHistory/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /games/{document=**} {
      // TODO: get to the bottom of doc mmmNCiIPKhnU0qiYxeYO beign written to over and over
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /rooms/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      allow read: if true;

      // On create, the new doc may only contain whitelisted fields.
      allow create: if isOwner()
                    && request.resource.data.keys().hasOnly(
                        ['name', 'email', 'rooms', 'nickname', 'photoURL']);

      // On update, only whitelisted fields may change. This is what blocks
      // a user from self-promoting to role: 'Admin'. Server-side writes
      // (e.g. addRoomToUsers, stats recalc) go through the admin SDK and
      // bypass this rule.
      allow update: if isOwner()
                    && request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['name', 'email', 'rooms', 'nickname', 'photoURL']);
    }

    // Word lists are public game content; only admins can edit.
    // Cloud Functions read these via the admin SDK and bypass the rule.
    match /wordlists/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
