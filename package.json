{
  "name": "codetango",
  "version": "1.0.0",
  "author": "Matt, Alex, Ryan, Armin, Justin, Bob, Tyler, Brik, JJ",
  "homepage": "https://codetango.web.app/",
  "scripts": {
    "serve": "ionic serve",
    "start": "ionic serve",
    "deploy:dev": "ionic build && firebase deploy -P dev",
    "deploy-functions:dev": "firebase deploy --only functions -P dev",
    "deploy-hosting:dev": "ionic build && firebase deploy --only hosting -P dev",
    "build:prod": "ionic build --prod --release",
    "deploy:prod": "npm run build:prod && firebase deploy -P prod",
    "deploy-functions:prod": "firebase deploy --only functions -P prod",
    "deploy-hosting:prod": "npm run build:prod && firebase deploy --only hosting -P prod",
    "indexes": "firebase firestore:indexes > firestore.indexes.json -P prod"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "~9.1.6",
    "@angular/core": "~9.1.6",
    "@angular/fire": "^6.0.2",
    "@angular/forms": "~9.1.6",
    "@angular/platform-browser": "~9.1.6",
    "@angular/platform-browser-dynamic": "~9.1.6",
    "@angular/router": "~9.1.6",
    "@angular/service-worker": "~9.1.6",
    "@ionic-native/core": "^5.0.7",
    "@ionic-native/splash-screen": "^5.0.0",
    "@ionic-native/status-bar": "^5.0.0",
    "@ionic/angular": "^5.0.0",
    "chart.js": "^2.9.3",
    "firebase": "^8.6.3",
    "lodash": "^4.17.20",
    "luxon": "^1.25.0",
    "moment": "^2.27.0",
    "rxjs": "~6.5.1",
    "tslib": "^1.10.0",
    "zone.js": "~0.10.2"
  },
  "devDependencies": {
    "@angular-devkit/architect": ">= 0.900 < 0.1100",
    "@angular-devkit/build-angular": "~0.901.5",
    "@angular/cli": "~9.1.5",
    "@angular/compiler": "~9.1.6",
    "@angular/compiler-cli": "~9.1.6",
    "@angular/language-service": "~9.1.6",
    "@ionic/angular-toolkit": "^2.1.1",
    "@types/jasmine": "~3.5.0",
    "@types/node": "^12.11.1",
    "firebase-tools": "^8.0.0",
    "jasmine-core": "^3.8.0",
    "karma": "~5.0.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~2.1.0",
    "karma-jasmine": "~3.0.1",
    "karma-jasmine-html-reporter": "^1.4.2",
    "ts-node": "~8.3.0",
    "typescript": "~3.8.3"
  },
  "description": "The best way to play codenames",
  "config": {
    "ionic_webpack": "./webpack.config.js"
  }
}
